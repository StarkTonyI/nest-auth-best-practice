

generator client {
  provider = "prisma-client-js" // <-- Добавь "-js" сюда
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user 
  admin
}

model User {
  id     String @id @default(cuid())
  email String  @unique
  username  String
  lastname String @default("N/A")
  password String 
  role Role @default(user)
  refreshToken String
  revoked Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id     String @id @default(cuid())
  authId String @unique
  username  String
  lastname String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id     String @id @default(cuid())
  token String @unique
  userId String @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}